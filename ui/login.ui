   <string notr="true">/*fondo*/
QDialog{
background-color: #0b0f1a;
}
/*frame*/
QFrame{
background-color: #0b0f1a;
border:2px solid #7df9ff;
border-radius: 24px;
color:white;

box-shadow:0 0 14px rgba(125,249,255,0.55);

}


/*label*/
QLabel#lblTitle{
color: #7df9ff;
font-size:28px;
font-weight: 800;
letter-spacing:1px;
border:none;
}

QLabel{
color: white;
font-size:14px;
border:none;
}



/*botones*/
QPushButton{
background-color: rgba(14,18,38,0.9);
color:#e7faff;

border: 2px solid #00ffa8;
border-radius: 22px;

padding: 12px 16px;
font-size:15px;
font-weight: 700;

box-shadow:0 0 12px rgba(0,255,168,0.45);
}

/*hover:cuando paso el maus*/
QPushButton:hover{
background-color: rgba(255,255,255,0.07);
color: white;

border: 2px solid #ff2bd6;
box-shadow: 0 0 18px rgba(255,43,214,0.65);
}

/*presionado*/
QPushButton:pressed{
background-color: rgba(0,255,168,0.10);
border:2px solid #7df9ff;

box-shadow:0 0 22 rgba(125,249,255,0.70);

}

/*TXT*/
QLineEdit{
background-color:#F5F3F0;
border: 2px solid #00ffa8;
color: black;
}

QCheckBox{
color: white;
border:1px solid black;

