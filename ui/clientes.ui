/*botones*/
QPushButton{
background-color: #f6f6f6;
border: 1px solid black;
border-radius: 25px;
padding: 8px 14px;
}

/*hover:cuando paso el maus*/
QPushButton:hover{
background-color: white;
color: black;
border: 2px solid #1b4f72;
}

/*presionado*/
QPushButton:pressed{
background-color: white;
color:black;
}

/*tabla*/
QTableWidget{
background-color: #ffffff;
border:2px solid black;
border-radius: 30px;
}

/*TXT*/
QLineEdit{
background-color:#ffffff;
border:1px solid black;
}
